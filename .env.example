# ─────────────────────────────────────────────
# TeacherRoleplayStudio — Environment Variables
# ─────────────────────────────────────────────
# For local dev: copy this file to `.env.local` and fill in values.
# For Vercel deploy: set these in Project Settings → Environment Variables.
# (Users can also enter their own Gemini API key in the app UI; env vars are only a fallback.)

# Which LLM backend to use: "google" (default) or "anthropic"
LLM_PROVIDER=google

# Google Gemini API key (get one free at https://aistudio.google.com/apikey)
# Optional if every user supplies their own key via the app UI.
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key-here

# Override model if you like (defaults shown)
# GOOGLE_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Anthropic Claude key (only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── Local-only proxy (skip on Vercel) ───────────
# Only needed if you're developing behind a network that blocks direct access
# to Google/Anthropic (e.g. mainland China). Point to your local proxy.
# DO NOT set these in the Vercel deployment — Vercel servers have direct access.
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
